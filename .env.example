# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Required for Telegram bot commands (/members, /balance, etc.)
SUPABASE_SERVICE_ROLE_KEY=

# Telegram bot (create via @BotFather)
TELEGRAM_BOT_TOKEN=
# Numeric chat IDs only (from Dashboard → Telegram → Sync). Example: 584729301
TELEGRAM_ADMIN_CHAT_IDS=
# More IDs or a group chat (groups are negative). Example: -1002876543210
TELEGRAM_NOTIFY_CHAT_IDS=
# Production only: public URL for instant replies (e.g. https://your-app.vercel.app/api/telegram/webhook)
TELEGRAM_WEBHOOK_URL=
# Optional: secret token when setting Telegram webhook
TELEGRAM_WEBHOOK_SECRET=
# Set to false to disable background polling in dev
# TELEGRAM_AUTO_POLL=false
# TELEGRAM_POLL_INTERVAL_MS=2500
